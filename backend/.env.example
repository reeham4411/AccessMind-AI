# ─────────────────────────────────────────────────────────────────────────────
# AI Accessibility Auditor — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in values.  Only PORT is required — Groq is optional.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server will listen on
PORT=3000

# Node environment: "development" | "production"
NODE_ENV=development


# ── Playwright ────────────────────────────────────────────────────────────────
# Max milliseconds to wait for a page to load (default: 30000 = 30 seconds)
PLAYWRIGHT_TIMEOUT=70000


# ── Groq AI  (OPTIONAL) ───────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
# If left blank the auditor still works — it just uses built-in static
# explanations instead of AI-generated ones.
GROQ_API_KEY=

# Groq model to use for AI explanations (default works well and is fast/free)
GROQ_MODEL=llama-3.3-70b-versatile
