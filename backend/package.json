{
  "name": "ai-accessibility-auditor-backend",
  "version": "1.0.0",
  "description": "Backend for AI Accessibility Auditor — scan any website for WCAG accessibility issues using Playwright + axe-core, with optional AI-powered explanations via Groq.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install:browsers": "npx playwright install chromium",
    "setup": "npm install && npm run install:browsers"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "axe-core",
    "playwright",
    "audit",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
